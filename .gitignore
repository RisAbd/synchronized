*service-account*.json
*-credentials.json
pacific-vault-*.json
gcloud-key*.json
/creds/

# крупные медиа рецитаций — не тащим в репо (голосовые .ogg-постановки задач храним)
*.mp4
*.mp3
*.m4a
*.wav
*.webm

# рабочие выгрузки конвейера
/work/
# кэш ML-моделей (whisper→HF, MMS-onnx forced) — качается, не в репо
/cache/
# хранилище обработки по записям (аудио + сырые ASR-ответы) — генерится, не в репо
/media/rec/
*.transcript*.txt
sync-map*.json
# но расшифровки голосовых-постановок — это документация, храним:
!media/*.transcript*.txt

# веб: код держим, тяжёлое аудио — нет
web/audio/

