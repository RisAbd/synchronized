# Пример окружения Django-сервиса. Скопируй в service/.env и правь.
# Пусто/по умолчанию — dev: SQLite + обработка в потоке (без Redis).

DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-insecure-key-change-me
# DJANGO_ALLOWED_HOSTS=*
# DJANGO_CSRF_TRUSTED=https://*.ngrok-free.app

# --- Postgres (если не задано — SQLite) ---
# POSTGRES_DB=synchronized
# POSTGRES_USER=synchronized
# POSTGRES_PASSWORD=synchronized
# POSTGRES_HOST=db

# --- Celery (если не задано — обработка в фоновом потоке) ---
# CELERY_BROKER_URL=redis://redis:6379/0

# --- распознаватель: whisper | google ---
SYNC_RECOGNIZER=whisper
# для whisper на CPU (docker без GPU):
# SYNC_ASR_DEVICE=cpu
# кэш ответов Google STT (если RECOGNIZER=google):
# GSTT_CACHE_DIR=/path/to/gcloud-speech-data
# ⚠️ ключ Google — только через env-путь, НЕ в репозиторий:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
